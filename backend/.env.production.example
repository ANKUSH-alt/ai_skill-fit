# Backend Environment Variables (.env.production)
# Copy this file and fill in your actual values

# Database (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# OpenAI (Optional - for LLM features)
OPENAI_API_KEY=sk-your-openai-api-key

# Security
SECRET_KEY=your_random_secret_key_min_32_characters_long
DEBUG=False

# CORS (Update with your frontend URL)
ALLOWED_ORIGINS=https://your-frontend-url.vercel.app,https://your-custom-domain.com

# Server
PORT=8000
WORKERS=2

# File Upload Limits
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_VIDEO_EXTENSIONS=.webm,.mp4,.mov
ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png

# AI Models (Optional - customize paths)
WHISPER_MODEL=base
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# Logging
LOG_LEVEL=INFO
